{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        ".vitepress/dist/**",
        "dist/**"
      ],
      "env": [
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_GITHUB_TOKEN",
        "NEXT_PUBLIC_GISCUS_REPO",
        "NEXT_PUBLIC_GISCUS_REPO_ID",
        "NEXT_PUBLIC_GISCUS_CATEGORY",
        "NEXT_PUBLIC_GISCUS_CATEGORY_ID"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "lint:fix": {},
    "clean": {
      "cache": false
    }
  }
}
